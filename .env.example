# --- DATABASE CONNECTION (SQLAlchemy / Postgres) ---
# Get these from Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI
# Or specific Pooling host / port if using Pooler
user=postgres.[YOUR-PROJECT-REF]
password=[YOUR-PASSWORD]
host=aws-1-ap-northeast-1.pooler.supabase.com
port=6543
dbname=postgres

# --- SUPABASE CLIENT SDK (File Uploads / Ingestion) ---
# Get these from Supabase Dashboard -> Project Settings -> API
# Use the 'anon' public key for client-side, or 'service_role' for backend specific bypass
SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=[YOUR-ANON-PUBLIC-KEY]
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

GEMINI_API_KEY=[YOUR-API-KEY]