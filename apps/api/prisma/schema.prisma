generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DomainEnum {
  GENERAL
  PERSONAL
  WORK
}

enum StatusEnum {
  ACTIVE
  ARCHIVED
}

model articles {
  id         Int       @id @default(autoincrement())
  title      String?   @db.VarChar
  content    String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)

  @@index([id], map: "ix_articles_id")
  @@index([title], map: "ix_articles_title")
}

model contextual_edges {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  source_id   String    @db.Uuid
  source_type String    @db.VarChar(50)
  target_id   String    @db.Uuid
  target_type String    @db.VarChar(50)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@index([source_id, source_type], map: "idx_edges_source")
  @@index([target_id, target_type], map: "idx_edges_target")
}

model execution_units {
  id                String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  status            String?     @default("To-Do") @db.VarChar(20)
  problem_statement String
  value_delivered   String?
  created_at        DateTime?   @default(now()) @db.Timestamptz(6)
  title             String      @default("Untitled Action") @db.VarChar(150)
  execution_log     String?
  domain            DomainEnum? @default(GENERAL)
}

model knowledge_fragments {
  id         String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  content    String
  domain     DomainEnum? @default(GENERAL)
  created_at DateTime?   @default(now()) @db.Timestamptz(6)
  title      String      @default("Untitled Fragment") @db.VarChar(150)
  hook       String?
}

model Sequence {
  id               String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  status           StatusEnum? @default(ACTIVE)
  problemStatement String?     @map("problem_statement") @db.Text
  valueDelivered   String?     @map("value_delivered") @db.Text
  title            String      @default("Untitled Sequence") @db.VarChar(150)
  domain           DomainEnum? @default(GENERAL)
  createdAt        DateTime?   @default(now()) @map("created_at") @db.Timestamptz(3)

  sequenceFrames    SequenceFrame[]
  sequenceKeyframes SequenceKeyframe[]

  @@map("sequences")
}

model Keyframe {
  id        String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title     String      @default("Untitled Keyframe") @db.VarChar(150)
  content   String?     @db.Text
  hook      String?     @db.Text
  domain    DomainEnum? @default(GENERAL)
  createdAt DateTime?   @default(now()) @map("created_at") @db.Timestamptz(3)

  keyframeFrames    KeyframeFrame[]
  sequenceKeyframes SequenceKeyframe[]

  @@map("keyframes")
}

model Frame {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  content   String?   @db.Text
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(3)

  sequenceFrames SequenceFrame[]
  keyframeFrames KeyframeFrame[]

  @@map("frames")
}

model SequenceFrame {
  sequenceId String   @map("sequence_id") @db.Uuid
  frameId    String   @map("frame_id") @db.Uuid
  addedAt    DateTime @default(now()) @map("added_at") @db.Timestamptz(3)

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  frame    Frame    @relation(fields: [frameId], references: [id], onDelete: Cascade)

  @@id([sequenceId, frameId, addedAt])
  @@map("sequence_frames")
}

model KeyframeFrame {
  keyframeId String   @map("keyframe_id") @db.Uuid
  frameId    String   @map("frame_id") @db.Uuid
  addedAt    DateTime @default(now()) @map("added_at") @db.Timestamptz(3)

  keyframe Keyframe @relation(fields: [keyframeId], references: [id], onDelete: Cascade)
  frame    Frame    @relation(fields: [frameId], references: [id], onDelete: Cascade)

  @@id([keyframeId, frameId, addedAt])
  @@map("keyframe_frames")
}

model SequenceKeyframe {
  sequenceId String   @map("sequence_id") @db.Uuid
  keyframeId String   @map("keyframe_id") @db.Uuid
  addedAt    DateTime @default(now()) @map("added_at") @db.Timestamptz(3)

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  keyframe Keyframe @relation(fields: [keyframeId], references: [id], onDelete: Cascade)

  @@id([sequenceId, keyframeId, addedAt])
  @@map("sequence_keyframes")
}
